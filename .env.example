# ── Free GPU Providers ────────────────────────────────────────────────────────

# 1. Replicate — $5 free credit, no card needed initially (RECOMMENDED FREE)
#    Sign up: https://replicate.com  →  Account → API tokens
#    Models: Wan 2.1 (fast), Minimax Video-01, Luma Ray
REPLICATE_API_TOKEN=your_replicate_token_here

# 2. HuggingFace — Fully free, just a free account needed
#    Sign up: https://huggingface.co  →  Settings → Access Tokens → New token
#    Models: ZeroScope 576w, ZeroScope XL, ModelScope
HUGGINGFACE_API_TOKEN=your_huggingface_token_here

# ── Paid Provider ────────────────────────────────────────────────────────────

# 3. Google Veo 2 — Best quality, paid API
#    Get key: https://aistudio.google.com/apikey  (requires Veo access)
VEO_API_KEY=your_google_ai_studio_api_key_here

# ── Claude Prompt Enhancement ─────────────────────────────────────────────────

# Anthropic API key for the ⚡ Enhance button (rewrites prompts for better results)
#    Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Priority ──────────────────────────────────────────────────────────────────
# App auto-detects which keys are set. UI shows only configured providers.
# If multiple are set, you can switch between them in the Options panel.
